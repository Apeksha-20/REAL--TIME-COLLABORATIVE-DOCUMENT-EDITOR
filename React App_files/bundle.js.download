n}\n\n/* BUTTON STYLE */\nbutton{\n  padding:10px 16px;\n  border:none;\n  border-radius:8px;\n  cursor:pointer;\n\n  font-size:18px;\n  font-weight:600;\n\n  background:#f1f1f1;\n  color:#333;\n\n  transition:all 0.25s ease;\n}\n\n/* BUTTON HOVER */\nbutton:hover{\n  background:#4b6cff;\n  color:white;\n  transform:translateY(-2px);\n  box-shadow:0 4px 10px rgba(0,0,0,0.25);\n}\n\n/* BUTTON CLICK */\nbutton:active{\n  transform:scale(0.95);\n}\n\n/* TOOLBAR DIVIDER */\n.toolbar-divider{\n  width:1px;\n  height:28px;\n  background:#ccc;\n  margin:0 6px;\n}\n\n/* DOCUMENT PAGE STYLE */\n.editor{\n  width:850px;\n  min-height:520px;\n\n  margin:auto;\n\n  background:white;\n\n  border-radius:6px;\n\n  padding:50px;\n\n  font-size:18px;\n  line-height:1.7;\n\n  color:#333;\n\n  outline:none;\n\n  text-align:left;\n\n  box-shadow:\n  0 12px 30px rgba(0,0,0,0.35);\n}\n\n/* WORD COUNTER */\n.word-count{\n  margin-top:15px;\n  font-weight:bold;\n  font-size:18px;\n  letter-spacing:0.5px;\n}\n\n/* RESPONSIVE DESIGN */\n@media (max-width:900px){\n\n  .editor-wrapper{\n    width:95%;\n  }\n\n  .editor{\n    width:100%;\n    padding:30px;\n  }\n\n}"],"sourceRoot":""}]);
